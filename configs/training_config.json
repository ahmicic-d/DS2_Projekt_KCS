{
  "model": {
    "name": "DeepSpeech2",
    "n_cnn_layers": 3,
    "n_rnn_layers": 5,
    "rnn_dim": 512,
    "n_class": 30,
    "n_feats": 128,
    "stride": 2,
    "dropout": 0.1
  },
  "audio": {
    "sample_rate": 16000,
    "n_mels": 128,
    "win_length_ms": 20,
    "hop_length_ms": 10,
    "n_fft": 512,
    "max_duration_sec": 20.0,
    "min_duration_sec": 0.5
  },
  "training": {
    "epochs": 100,
    "batch_size": 16,
    "learning_rate": 0.0005,
    "weight_decay": 1e-05,
    "scheduler": "OneCycleLR",
    "grad_clip": 5.0,
    "early_stopping_patience": 15,
    "save_every_n_epochs": 10,
    "log_every_n_steps": 10
  },
  "data": {
    "train_manifest": "data/processed/train/manifest.csv",
    "dev_manifest": "data/processed/dev/manifest.csv",
    "test_manifest": "data/processed/test/manifest.csv",
    "alphabet": "configs/alphabet_hr.txt",
    "num_workers": 4
  },
  "augmentation": {
    "enabled": true,
    "time_mask_max": 50,
    "freq_mask_max": 15,
    "n_time_masks": 2,
    "n_freq_masks": 2,
    "noise_factor": 0.005
  },
  "decoding": {
    "beam_width": 200,
    "lm_path": null,
    "lm_alpha": 0.75,
    "lm_beta": 1.85
  },
  "paths": {
    "model_dir": "models/",
    "results_dir": "results/",
    "log_dir": "results/logs/"
  }
}